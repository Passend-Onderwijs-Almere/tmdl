				    MAX ( 'psql_datumtabel'[datum] )
				VAR StartOfDisplay =
				    DATE ( 2022, 8, 1 )
				VAR TodayDate =
				    TODAY ()
				
				// CurrentDate mag niet verder gaan dan vandaag
				VAR EffectiveDate =
				    IF ( CurrentDate > TodayDate, TodayDate, CurrentDate )
				
				// Rolling-12 window
				VAR StartDay =
				    EffectiveDate - 365       // of: EDATE(EffectiveDate, -12)
				VAR EndDay =
				    EffectiveDate
				
				VAR Result =
				    CALCULATE (
				        [aantal_aanvragen_afgegeven_tlv],
				        DATESBETWEEN (
				            'psql_datumtabel'[datum],
				            StartDay,
				            EndDay
				        )
				    )
				
				RETURN
				    IF ( EffectiveDate < StartOfDisplay, BLANK(), Result )
				
