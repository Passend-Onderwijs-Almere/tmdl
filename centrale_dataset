		/// Aantal leerlingen op Teldatum 1 feb die niet in de toekomst ligt (≤ CurrentDate) en niet leeg is...
		measure aantal_leerlingen_po_sbo_vo_laatste_per_datum =
				
				VAR CurrentDate =
				    MAX ( psql_datumtabel[datum] ) // Laatste tellingdatum vinden, maar andere filters (zoals dimscholen) behouden
				VAR LaatsteTeldatum =
				    CALCULATE (
				        MAX ( duok_aantallen_vestigingen_bo_sbo_vo[Teldatum_universeel] ),
				        FILTER (
				            ALL ( duok_aantallen_vestigingen_bo_sbo_vo[Teldatum_universeel] ),
				            // filter alleen Teldatum kolom
				            duok_aantallen_vestigingen_bo_sbo_vo[Teldatum_universeel] <= CurrentDate
