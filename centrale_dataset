	ref table MeasureTable

		/// Aantal dossiernummers geteld in inspectierapportage. Deze wordt gedeeld door het aantal leerlingen uit DUO.
		/// leerling measure: Aantal leerlingen binnen ons eigen samenwerkingsverband in het po, sbo en vo. Bij dit aantal zitten ook de leerlingen van buiten ons samenwerkingsverband inbegrepen die onderwijs volgen binnen ons swv.
		measure %_aanvragen_tov_eigen_populatie =
				
				DIVIDE (
				    [Aantal aanvragen],
				    [aantal_leerlingen_po_sbo_vo],
				    0
				)
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: measures_tlv\inspectierapportage
			lineageTag: b32a0923-3273-4460-89c4-be2cbb300bcc

		/// aantal bekostigde leerlingen tov een jaar eerder
		/// kopie van %_groei_aantal_so_leerlingen_tov_vorig_jaar
		measure %_groei_aantal_leerlingen_onderstbek_tov_vorig_jaar =
				
				VAR huidig =
				    SUM ( duok_aantallen_ondersteuningsbekost_swv_po_vo[totaal] )
				VAR vorig_jaar =
				    CALCULATE (
				        SUM ( duok_aantallen_ondersteuningsbekost_swv_po_vo[totaal] ),
				        PREVIOUSYEAR ( psql_datumtabel[februaritelling] )
				    )
				RETURN
				    IF ( ISBLANK ( vorig_jaar ), BLANK (), DIVIDE ( huidig, vorig_jaar ) - 1 )
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: measures_aantallen leerlingen
			lineageTag: 2c3eca84-8f34-4323-9cfc-381315d70f46

