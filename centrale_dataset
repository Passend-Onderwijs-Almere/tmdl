		/// Telt het aantal regels van actief verzuim als current date (max psql_datumtabel) kleiner of gelijk is aan vandaag EN current date groter is dan verzuim start (min indigo_verzuim).
		/// 
		/// Toegepaste filters:
		/// - Het datum filter wordt verwijderd,
		/// - Verzuim sinds moet kleiner of gelijk zijn aan current date
		/// - Einde verzuim moet groter zijn dat current date OF einde verzuim moet leeg zijn.
		/// 
		/// Note: current_date gaat niet hoger dan 24-4-2024
		measure actief_verzuim_dax =
				
				VAR current_date=MAX(psql_datumtabel[datum])
				VAR verzuim_start=MIN(indigo_verzuim_povo[verzuim_sinds])
				VAR actief_verzuim=
				CALCULATE(COUNTROWS(indigo_verzuim_povo),
				ALL(psql_datumtabel[datum]),
				indigo_verzuim_povo[verzuim_sinds]<=current_date,
				indigo_verzuim_povo[einde_verzuim]>current_date
				||
				ISBLANK(indigo_verzuim_povo[einde_verzuim]))
				VAR result =
				IF(current_date<=TODAY() && current_date>=verzuim_start,actief_verzuim)
				RETURN result
			formatString: 0
			displayFolder: measures_verzuim
			lineageTag: 8d237450-5f98-40f5-9dbf-5fb7a9bd9c5f

